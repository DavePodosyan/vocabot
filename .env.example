# Instructions for Telegram Bot Token
# 1. Open Telegram and search for @BotFather
# 2. Send the command /newbot and follow the instructions
# 3. Once created, BotFather will give you a token that looks like: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# 4. Copy that token and paste it below, replacing YOUR_TELEGRAM_BOT_TOKEN_HERE

TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# (Optional) Yandex Dictionary API key for highly accurate translations based on part-of-speech
YANDEX_DICTIONARY_KEY=""

# Choose the mode to run the bot: 'polling' (default) or 'webhook'
MODE="polling"

# Webhook configuration (only used if MODE=webhook)
PORT=8443
WEBHOOK_URL="https://your-ngrok-url.ngrok-free.app"

# Restrict the bot to specific user IDs (comma separated). 
# If empty, anyone can use it.
# To find your ID, just message the bot before setting this, and it will tell you!
ALLOWED_USER_IDS=""
